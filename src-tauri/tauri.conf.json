{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ACE-Lite",
  "version": "0.1.0",
  "identifier": "com.local.acelite",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:8787",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ACE-Lite",
        "width": 900,
        "height": 750,
        "resizable": true,
        "fullscreen": false,
        "closable": true,
        "skipTaskbar": false,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "main-capability",
          "windows": [
            "main"
          ],
          "permissions": [
            "core:default",
            "dialog:allow-save",
            "fs:allow-write-file",
            "fs:allow-write-text-file",
            "shell:default",
            "process:allow-exit",
            "core:window:allow-start-dragging",
            "core:window:allow-minimize",
            "core:window:allow-toggle-maximize",
            "core:window:allow-close"
          ]
        }
      ]
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
